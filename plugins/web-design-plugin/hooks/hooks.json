{
  "description": "Tracks web-design command execution statistics — agent count, media generated, timing",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/track-stats.sh",
            "timeout": 3,
            "async": true
          }
        ]
      }
    ]
  }
}
