{
  "description": "media-plugin hooks: auto-run drawio edge-routing postprocessor after every .drawio Write; sanity-check + render reminder after every .svg Write",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/postprocess-drawio.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-svg.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
